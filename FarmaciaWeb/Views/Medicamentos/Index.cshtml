@model IEnumerable<FarmaciaWeb.Models.Medicamento>
@{
    ViewData["Title"] = "Medicamentos";
}

<h2 class="mb-4">Medicamentos</h2>

<a asp-action="Create" class="btn btn-primary mb-3">Nuevo Medicamento</a>
<form method="get" class="row g-2 mb-3">
    <div class="col-md-4">
        <input type="text" name="buscar" value="@ViewBag.Buscar" class="form-control" placeholder="Buscar por nombre..." />
    </div>
    <div class="col-md-3">
        <select name="categoriaId" class="form-select">
            <option value="">-- Todas las categorías --</option>
            @foreach (var cat in ViewBag.Categorias)
            {
                <option value="@cat.Id" selected="@(ViewBag.CategoriaId == cat.Id)">@cat.Nombre</option>
            }
        </select>
    </div>
    <div class="col-md-3">
        <select name="estanteId" class="form-select">
            <option value="">-- Todos los estantes --</option>
            @foreach (var est in ViewBag.Estantes)
            {
                <option value="@est.Id" selected="@(ViewBag.EstanteId == est.Id)">@est.Nombre</option>
            }
        </select>
    </div>
    <div class="col-md-2">
        <button type="submit" class="btn btn-primary w-100">Filtrar</button>
    </div>
</form>
@if (TempData["Mensaje"] != null)
{
    <div class="alert alert-success">@TempData["Mensaje"]</div>
}
<table class="table table-bordered table-hover">
    <thead class="table-dark">
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Vencimiento</th>
            <th>Categoría</th>
            <th>Estante</th>
            <th>Estado</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            var hoy = DateTime.Today;
            var rowClass = "";
            var etiqueta = "";

            if (item.FechaVencimiento < hoy)
            {
                rowClass = "table-danger";
                etiqueta = "Vencido";
            }
            else if (item.FechaVencimiento <= hoy.AddDays(30))
            {
                rowClass = "table-warning";
                etiqueta = "Por vencer";
            }
            else if (item.Stock < 10)
            {
                rowClass = "table-info";
                etiqueta = "Bajo stock";
            }

            <tr class="@rowClass">
                <td>@item.Nombre</td>
                <td>@item.Precio.ToString("C")</td>
                <td>@item.Stock</td>
                <td>@item.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                <td>@item.Categoria?.Nombre</td>
                <td>@item.Estante?.Nombre</td>
                <td>
                    @if (item.Estado)
                    {
                        <span class="badge bg-success">Activo</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Inactivo</span>
                    }
                    @if (!string.IsNullOrEmpty(etiqueta))
                    {
                        <span class="badge bg-dark ms-1">@etiqueta</span>
                    }
                </td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-sm btn-warning">Editar</a>
                    <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-info">Detalles</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-sm btn-danger" onclick="return confirm('¿Está seguro de eliminar este medicamento?')">Eliminar</a>
                </td>
            </tr>
        }
    </tbody>
</table>