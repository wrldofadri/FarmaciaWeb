@model IEnumerable<FarmaciaWeb.Models.Medicamento>
@{
    ViewData["Title"] = "Medicamentos Vencidos";
}

<h2 class="mb-4">Reporte de Medicamentos Vencidos</h2>

<a asp-action="Index" class="btn btn-secondary mb-3">Volver al Dashboard</a>

<table class="table table-bordered table-hover">
    <thead class="table-danger">
        <tr>
            <th>Nombre</th>
            <th>Precio</th>
            <th>Stock</th>
            <th>Fecha Vencimiento</th>
            <th>Categoría</th>
            <th>Estante</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Nombre</td>
                <td>@item.Precio.ToString("C")</td>
                <td>@item.Stock</td>
                <td>@item.FechaVencimiento.ToString("dd/MM/yyyy")</td>
                <td>@item.Categoria?.Nombre</td>
                <td>@item.Estante?.Nombre</td>
            </tr>
        }
    </tbody>
</table>